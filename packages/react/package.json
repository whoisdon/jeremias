{
  "name": "@jeremias/react",
  "version": "0.1.0",
  "description": "Componente React do JEREMIAS",
  "license": "MIT",
  "author": "JEREMIAS contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/whoisdon/jeremias.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/whoisdon/jeremias/issues"
  },
  "homepage": "https://github.com/whoisdon/jeremias/tree/main/packages/react#readme",
  "keywords": [
    "jeremias",
    "react",
    "pet",
    "duck",
    "nextjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@jeremias/core": "0.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external react --external react-dom",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
